# Snowflake (see https://sequelize.org/docs/v6/other-topics/dialect-specific-things/#snowflake-experimental)
# Account identifier: orgname-accountname or account.region.cloud (no https://)
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USERNAME=demo_user
SNOWFLAKE_PASSWORD=change_me
# Shared sample database (read-only in many accounts)
SNOWFLAKE_DATABASE=snowflake_sample_data
SNOWFLAKE_SCHEMA=TPCDS_SF10TCL
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# Optional
# SNOWFLAKE_ROLE=ACCOUNTADMIN

PORT=4000
